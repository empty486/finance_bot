# 🚀 Telegram Bot Configuration

# Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 📦 Database Configuration
# For Docker: postgresql+asyncpg://user:password@postgres:5432/finance_db
# For Local: postgresql+asyncpg://user:password@localhost:5432/finance_db
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/finance_db
